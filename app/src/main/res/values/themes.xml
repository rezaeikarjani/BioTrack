<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.BioTrack" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Customize your light theme here. -->
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, here an opaque color. -->
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <!-- Use a drawable as the splash screen icon. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/heart_icon</item>
        <!-- Set the theme of the Activity that directly follows your splash screen. -->
        <item name="postSplashScreenTheme">@style/Theme.BioTrack</item>
    </style>
</resources>